# ===================================================================
# giipAgent CONFIGURATION (SAMPLE)
# ===================================================================
# ⚠️ WARNING: DO NOT MODIFY THIS FILE INSIDE THE giipAgentWin FOLDER.
# ⚠️ THIS IS A SAMPLE TEMPLATE.
#
# 🛠️ HOW TO USE:
# 1. Copy this file to the PARENT directory of giipAgentWin
# 2. Or place it in %USERPROFILE%\giipAgent.cfg
# 3. Update the 'sk' and 'lssn' values in the copied file.
# ===================================================================

# V2 API Endpoint
apiaddrv2 = "https://giipfaw.azurewebsites.net/api/giipApiSk2"

# Security Token (Use 'token' in API calls, NOT 'sk')
sk = "YOUR_KVS_TOKEN"

# Logical Server Serial Number
lssn = "YOUR_LSSN"

# Polling Delay (seconds)
giipagentdelay = "60"

# Debug Mode (0=Off, 1=On)
debug = "0"

# Git Branch for Agent Auto-Update
branch = "real"
